// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Employee {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String
  email           String   @unique
  gender          String
  jobTitle        String
  department      String
  country         String
  currency        String
  salary          Float
  previousSalary  Float?
  salaryUpdatedAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([department])
  @@index([country])
  @@index([department, country])
}

model ExchangeRate {
  id           String @id @default(uuid())
  fromCurrency String @unique
  toCurrency   String @default("USD")
  rate         Float
}
